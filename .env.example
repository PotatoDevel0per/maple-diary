# openssl rand -base64 32 로 생성
AUTH_SECRET=

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 클라이언트 ID
# 승인된 리디렉션 URI: https://maplediary.site/api/auth/callback/google (개발: http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# SQLite 파일 경로 (도커에서는 /data/maple.db 볼륨 사용)
DATABASE_PATH=./data/maple.db

# 리버스 프록시(Caddy) 뒤에서 필요
AUTH_TRUST_HOST=true
AUTH_URL=https://maplediary.site
